PORT=5000
DATABASE_URL=postgresql://supportbot:supportbot@localhost:5432/supportbot

# Required for real chat responses.
# Use OPENAI_API_KEY for standard OpenAI, or the Replit integration variables below.
OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=

# Optional: only needed for Microsoft Graph OneDrive/SharePoint browsing.
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=

# Optional but recommended if session middleware is added/enabled later.
SESSION_SECRET=dev-local-change-me

# Zoho Desk integration (ticket lookup + email drafting tab)
ZOHO_REFRESH_TOKEN=
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
